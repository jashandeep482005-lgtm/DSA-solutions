#include <stack>

using namespace std;

class MyQueue {
private:
    stack<int> inputStack;  // Holds elements pushed into the queue
    stack<int> outputStack; // Holds elements ready to be popped/peeked in FIFO order

    /**
     * Helper function to transfer elements from inputStack to outputStack
     * whenever outputStack is empty.
     */
    void transferElements() {
        if (outputStack.empty()) {
            while (!inputStack.empty()) {
                outputStack.push(inputStack.top());
                inputStack.pop();
            }
        }
    }

public:
    MyQueue() {
        // Constructor initialization
    }
    
    // Pushes element x to the back of the queue.
    void push(int x) {
        inputStack.push(x);
    }
    
    // Removes the element from the front of the queue and returns it.
    int pop() {
        transferElements();
        int val = outputStack.top();
        outputStack.pop();
        return val;
    }
    
    // Returns the element at the front of the queue.
    int peek() {
        transferElements();
        return outputStack.top();
    }
    
    // Returns true if the queue is empty, false otherwise.
    bool empty() {
        return inputStack.empty() && outputStack.empty();
    }
};

