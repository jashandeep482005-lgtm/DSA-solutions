#include <vector>

using namespace std;

class Solution {
private:
    
    void calculatePrefixProducts(const vector<int>& nums, vector<int>& answer) {
        int leftProduct = 1;
        for (size_t i = 0; i < nums.size(); ++i) {
            answer[i] = leftProduct;
            leftProduct *= nums[i];
        }
    }

   
    void multiplySuffixProducts(const vector<int>& nums, vector<int>& answer) {
        int rightProduct = 1;
        for (int i = nums.size() - 1; i >= 0; --i) {
            answer[i] *= rightProduct;
            rightProduct *= nums[i];
        }
    }

public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n = nums.size();
        vector<int> answer(n, 1);

        calculatePrefixProducts(nums, answer);

        multiplySuffixProducts(nums, answer);

        return answer;
    }
};
